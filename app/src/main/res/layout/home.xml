<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/home"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#DD9A40"
    tools:context=".MainActivity">


    <ImageView
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginLeft="280dp"
        android:layout_marginTop="50dp"
        app:srcCompat="@drawable/_74268007_1122278329188448_2909077324873343272_n" />

    <ImageView
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_marginTop="630dp"
        android:scaleType="fitXY"
        android:background="#DDEB9D"/>

    <ImageView
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_marginBottom="650dp"
        android:background="@drawable/header"
        android:scaleType="fitXY" />

    <ImageView
        android:layout_width="115dp"
        android:layout_height="fill_parent"
        android:layout_marginBottom="599dp"
        android:background="@drawable/subheader"
        android:elevation="-1dp"
        android:layout_alignParentEnd="true"
        android:scaleType="fitXY" />

    <ImageView
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginTop="13dp"
        android:layout_marginRight="70dp"
        android:layout_alignParentEnd="true"
        app:srcCompat="@drawable/seed" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="100"
        android:textStyle="bold"
        android:textSize="30dp"
        android:shadowColor="#2D3E1F"
        android:shadowDx="8"
        android:shadowDy="8"
        android:shadowRadius="3"
        android:textColor="#ffff"
        android:layout_marginRight="15dp"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="17dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chapter 1 - Basic Syntax"
        android:textStyle="bold"
        android:textSize="20dp"
        android:shadowColor="#2D3E1F"
        android:shadowDx="8"
        android:shadowDy="8"
        android:shadowRadius="3"
        android:textColor="#ffff"
        android:layout_marginLeft="15dp"
        android:layout_marginTop="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0/5 Modules Completed"
        android:textStyle="bold"
        android:textSize="15dp"
        android:shadowColor="#2D3E1F"
        android:shadowDx="8"
        android:shadowDy="8"
        android:shadowRadius="3"
        android:textColor="#ffff"
        android:layout_marginLeft="15dp"
        android:layout_marginTop="48dp" />

    <ProgressBar
        android:id="@+id/current_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="250dp"
        android:layout_height="10dp"
        android:progress="50"
        android:max="100"
        android:layout_marginTop="38dp"
        android:layout_marginLeft="15dp"
        android:progressDrawable="@drawable/rounded_progress"/>

    <ImageView
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_marginTop="655dp"
        android:layout_marginLeft="71dp"
        app:srcCompat="@drawable/interface_whitebackground" />

    <ImageView
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_marginTop="655dp"
        android:layout_marginLeft="255dp"
        app:srcCompat="@drawable/interface_whitebackground" />

    <ImageView
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginTop="665dp"
        android:layout_marginLeft="80dp"
        app:srcCompat="@drawable/home" />

    <ImageView
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginLeft="265dp"
        android:layout_marginTop="665dp"
        app:srcCompat="@drawable/_26472" />

    <ImageView
        android:layout_width="300dp"
        android:layout_height="250dp"
        android:layout_marginLeft="60dp"
        android:layout_marginTop="220dp"
        android:scaleType="fitXY"
        app:srcCompat="@drawable/interface_background" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lessons"
        android:textSize="50sp"
        android:layout_marginTop="150dp"
        android:layout_marginLeft="40dp"
        />

    <ImageView
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginLeft="110dp"
        android:layout_marginTop="240dp"
        app:srcCompat="@drawable/java_icon_1511x2048_6ikx8301" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Basics"
        android:textSize="50sp"
        android:layout_marginTop="475dp"
        android:layout_marginLeft="130dp"


</RelativeLayout>