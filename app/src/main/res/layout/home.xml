<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/home"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#DD9A40"
    tools:context=".MainActivity">


    <ImageView
        android:layout_width="fill_parent"
        android:layout_height="80dp"
        android:background="@drawable/header"
        android:scaleType="fitXY" />

    <ImageView
        android:layout_width="100dp"
        android:layout_height="130dp"
        android:background="@drawable/subheader"
        android:elevation="-1dp"
        android:layout_alignParentEnd="true"
        android:scaleType="fitXY" />

    <ImageView
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginTop="13dp"
        android:layout_marginRight="70dp"
        android:layout_alignParentEnd="true"
        app:srcCompat="@drawable/seed" />

    <ImageView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="83dp"
        android:layout_marginRight="53dp"
        android:layout_alignParentEnd="true"
        app:srcCompat="@drawable/heart" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="100"
        android:textStyle="bold"
        android:textSize="30dp"
        android:shadowColor="#2D3E1F"
        android:shadowDx="8"
        android:shadowDy="8"
        android:shadowRadius="3"
        android:textColor="#ffff"
        android:layout_marginRight="15dp"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="17dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="10"
        android:textStyle="bold"
        android:textSize="30dp"
        android:shadowColor="#2D3E1F"
        android:shadowDx="8"
        android:shadowDy="8"
        android:shadowRadius="3"
        android:textColor="#ffff"
        android:layout_marginRight="15dp"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="80dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chapter 1 - Basic Syntax"
        android:textStyle="bold"
        android:textSize="20dp"
        android:shadowColor="#2D3E1F"
        android:shadowDx="8"
        android:shadowDy="8"
        android:shadowRadius="3"
        android:textColor="#ffff"
        android:layout_marginLeft="15dp"
        android:layout_marginTop="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0/5 Modules Completed"
        android:textStyle="bold"
        android:textSize="15dp"
        android:shadowColor="#2D3E1F"
        android:shadowDx="8"
        android:shadowDy="8"
        android:shadowRadius="3"
        android:textColor="#ffff"
        android:layout_marginLeft="15dp"
        android:layout_marginTop="48dp" />

    <ProgressBar
        android:id="@+id/current_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="250dp"
        android:layout_height="10dp"
        android:progress="50"
        android:max="100"
        android:layout_marginTop="38dp"
        android:layout_marginLeft="15dp"
        android:progressDrawable="@drawable/rounded_progress"/>

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="100dp"
        android:layout_marginLeft="30dp"
        android:background="@drawable/levelbox"/>

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="99dp"
        android:layout_marginLeft="30dp"
        android:src="@drawable/one"/>

    <ImageView
        android:layout_width="67dp"
        android:layout_height="100dp"
        android:layout_marginLeft="35dp"
        android:layout_marginTop="190dp"
        android:src="@drawable/line" />

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="300dp"
        android:layout_marginLeft="30dp"
        android:background="@drawable/levelbox"/>

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="299dp"
        android:layout_marginLeft="30dp"
        android:src="@drawable/two"/>

    <ImageView
        android:layout_width="67dp"
        android:layout_height="100dp"
        android:layout_marginLeft="35dp"
        android:layout_marginTop="390dp"
        android:src="@drawable/line" />

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="500dp"
        android:layout_marginLeft="30dp"
        android:background="@drawable/levelbox"/>

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="499dp"
        android:layout_marginLeft="30dp"
        android:src="@drawable/three"/>

    <ImageView
        android:layout_width="280dp"
        android:layout_height="333dp"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="200dp"
        android:layout_marginRight="20dp"
        android:src="@drawable/syntax_preview" />

    <ImageView
        android:layout_width="173dp"
        android:layout_height="207dp"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="370dp"
        android:layout_marginRight="20dp"
        android:src="@drawable/output_preview" />

    <ImageView
        android:layout_width="145dp"
        android:layout_height="154dp"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="200dp"
        android:layout_marginEnd="-2dp"
        android:layout_marginRight="20dp"
        android:src="@drawable/javocado" />

    <ImageView
        android:id="@+id/footer"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/footer"
        android:layout_alignParentBottom = "true"/>

    <ImageView
        android:id="@+id/home_button"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginLeft="130dp"
        android:layout_marginBottom="15dp"
        android:src="@drawable/home"
        android:layout_alignParentBottom = "true"/>

    <ImageView
        android:id="@+id/profile_button"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginLeft="230dp"
        android:layout_marginBottom="15dp"
        android:src="@drawable/profile"
        android:layout_alignParentBottom = "true"/>


</RelativeLayout>